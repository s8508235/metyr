{
  "manifest_version": 3,
  "name": "Gardenia",
  "version": "1.0",
  "description": "Send string to local inference server to transcribe string",
  "permissions": ["contextMenus", "activeTab"],
  "host_permissions": ["http://127.0.0.1/*"],
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "translate-selection": {
      "suggested_key": {
        "default": "Ctrl+D",
        "mac": "Command+D"
      },
      "description": "Translate selected text"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
